# =============================================================================
# laliga-cloudflare-toggle - Configuration
# =============================================================================

# --- Cloudflare (required) ---

# API token with "Zone DNS Edit" permission
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# Domains to manage: ZONE_ID:DOMAIN separated by commas
# Find your Zone ID: Cloudflare dashboard > domain > Overview > right sidebar
#
# Single domain:
#   DOMAINS="abc123def456:example.com"
#
# Multiple domains:
#   DOMAINS="abc123:example.com,def456:example.org"
DOMAINS=""

# --- Telegram notifications (optional) ---

# Create a bot with @BotFather, get chat_id from @userinfobot
# Leave empty to disable notifications
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Options ---

# Dry run mode: detect blocks without modifying Cloudflare
DRY_RUN=false

# Check interval in seconds (Docker only, cron users set their own schedule)
CHECK_INTERVAL=300

# Max hours to keep proxy disabled if hayahora.futbol API is unreachable
MAX_DISABLED_HOURS=12
